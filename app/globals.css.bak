@import "tailwindcss";

:root { --vh: 1vh; }

body {
  overscroll-behavior: none;
  background-color: #f1f5f9;
}

/* --- YAZDIRMA AYARLARI --- */
@media print {
  body * { visibility: hidden !important; }
  #print-area, #print-area * { visibility: visible !important; }
  #print-area {
    position: fixed !important;
    left: 0; top: 0;
    width: 80mm !important;
    padding: 4mm !important;
    font-size: 10px !important;
    background: white !important;
    z-index: 99999 !important;
  }
  #print-area table { width: 100% !important; border-collapse: collapse !important; }
  #print-area th, #print-area td { border: 1px solid #333 !important; padding: 2px 4px !important; font-size: 9px !important; }
  #print-irsaliye, #print-irsaliye * { visibility: visible !important; }
  #print-irsaliye {
    position: fixed !important;
    left: 0; top: 0;
    width: 210mm !important;
    padding: 15mm !important;
    font-size: 11px !important;
    background: white !important;
    z-index: 99999 !important;
  }
  #print-irsaliye table { width: 100% !important; border-collapse: collapse !important; }
  #print-irsaliye th, #print-irsaliye td { border: 1px solid #333 !important; padding: 4px 8px !important; font-size: 10px !important; }
}
