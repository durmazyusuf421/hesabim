"use client";
import React, { useEffect, useState, useMemo } from "react";
import { supabase } from "@/app/lib/supabase";
import { useAuth } from "@/app/lib/useAuth";
import Link from "next/link";
import { BarChart, Bar, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer } from "recharts";

// --- TİP TANIMLAMALARI ---
interface SiparisData { id: number; alici_firma_id?: number; toplam_tutar: string | number | null; durum: string; created_at?: string; siparis_no?: string; }
interface AylikVeri { ay: string; tutar: number; }

const parseTutar = (val: string | number | null | undefined): number => {
    if (!val) return 0;
    if (typeof val === "number") return val;
    let str = String(val).trim();
    if (str.includes(".") && str.includes(",")) { str = str.replace(/\./g, "").replace(",", "."); }
    else if (str.includes(",")) { str = str.replace(",", "."); }
    const num = Number(str);
    return isNaN(num) ? 0 : num;
};

export default function AnaSayfa() {
    const { aktifSirket, kullanici, kullaniciRol, isYonetici } = useAuth();
    const [yukleniyor, setYukleniyor] = useState(true);

    // VERİ STATELERİ
    const [siparisler, setSiparisler] = useState<SiparisData[]>([]);
    const [firmaMap, setFirmaMap] = useState<Record<number, string>>({});
    const [toplamMusteri, setToplamMusteri] = useState(0);
    const [bekleyenB2B, setBekleyenB2B] = useState(0);

    // VERİ ÇEKME
    useEffect(() => {
        if (!aktifSirket) return;
        if (aktifSirket.rol !== "TOPTANCI") { window.location.href = "/login"; return; }
        if (!kullaniciRol.includes("YONETICI")) { setYukleniyor(false); return; }

        async function verileriTopla() {
            setYukleniyor(true);
            try {
                const sirketId = aktifSirket!.id;

                // Firmalar
                const { data: fData } = await supabase.from("firmalar").select("id, unvan").eq("sahip_sirket_id", sirketId);
                const map: Record<number, string> = {};
                if (fData) fData.forEach(f => { map[f.id] = f.unvan; });
                setFirmaMap(map);
                setToplamMusteri(fData?.length || 0);

                // Siparişler
                const { data: sData } = await supabase.from("siparisler").select("*").eq("satici_sirket_id", sirketId).order("created_at", { ascending: false });
                setSiparisler(sData || []);

                // Bekleyen B2B istekleri
                const { count } = await supabase.from("b2b_baglantilar").select("id", { count: "exact", head: true }).eq("toptanci_id", sirketId).eq("durum", "BEKLIYOR");
                setBekleyenB2B(count || 0);
            } catch {
            }
            setYukleniyor(false);
        }

        verileriTopla();
    }, [aktifSirket, kullaniciRol]);

    // HESAPLAMALAR
    const bugun = new Date().toISOString().split("T")[0];

    const bugunkuSiparisler = useMemo(() =>
        siparisler.filter(s => s.created_at?.startsWith(bugun)),
    [siparisler, bugun]);

    const bugunkuCiro = useMemo(() =>
        bugunkuSiparisler.reduce((acc, s) => acc + parseTutar(s.toplam_tutar), 0),
    [bugunkuSiparisler]);

    const bekleyenSayisi = useMemo(() =>
        siparisler.filter(s => s.durum === "YENI" || s.durum === "HAZIRLANIYOR" || s.durum === "Onay Bekliyor").length,
    [siparisler]);

    // AYLIK SATIŞ GRAFİĞİ (Son 6 ay)
    const aylikGrafik = useMemo((): AylikVeri[] => {
        const ayIsimleri = ["Oca", "Şub", "Mar", "Nis", "May", "Haz", "Tem", "Ağu", "Eyl", "Eki", "Kas", "Ara"];
        const sonAltiAy: AylikVeri[] = [];

        for (let i = 5; i >= 0; i--) {
            const d = new Date();
            d.setMonth(d.getMonth() - i);
            const ayKey = `${d.getFullYear()}-${(d.getMonth() + 1).toString().padStart(2, "0")}`;
            const ayIsim = `${ayIsimleri[d.getMonth()]} ${d.getFullYear().toString().slice(2)}`;

            const ayToplam = siparisler
                .filter(s => s.created_at?.startsWith(ayKey) && s.durum !== "IPTAL")
                .reduce((acc, s) => acc + parseTutar(s.toplam_tutar), 0);

            sonAltiAy.push({ ay: ayIsim, tutar: ayToplam });
        }
        return sonAltiAy;
    }, [siparisler]);

    // SON SİPARİŞLER (5 adet)
    const sonBesSiparis = useMemo(() =>
        siparisler.slice(0, 5).map(s => ({
            ...s,
            musteriAdi: (s.alici_firma_id && firmaMap[s.alici_firma_id]) || "Bilinmiyor"
        })),
    [siparisler, firmaMap]);

    const kullaniciAdi = kullanici?.ad_soyad || "Yönetici";

    if (!aktifSirket) return <div className="h-full flex items-center justify-center bg-slate-100 font-bold text-slate-500">Sistem Doğrulanıyor...</div>;

    const durumBadge = (durum: string) => {
        switch (durum) {
            case "YENI": return "bg-amber-100 text-amber-700";
            case "HAZIRLANIYOR": return "bg-blue-100 text-blue-700";
            case "TAMAMLANDI": return "bg-emerald-100 text-emerald-700";
            case "IPTAL": return "bg-red-100 text-red-700";
            default: return "bg-slate-100 text-slate-600";
        }
    };

    return (
        <main className="flex-1 flex flex-col h-full overflow-hidden bg-slate-50 relative w-full">
                {/* HEADER */}
                <header className="h-14 md:h-16 bg-white border-b border-slate-200 flex items-center justify-between px-4 md:px-6 shrink-0 shadow-sm">
                    <div className="flex items-center gap-3">
                        <button onClick={() => window.dispatchEvent(new Event('openMobilMenu'))} className="md:hidden w-9 h-9 bg-slate-100 rounded-lg flex items-center justify-center text-slate-600"><i className="fas fa-bars"></i></button>
                        <h1 className="text-sm md:text-lg font-bold text-slate-800">
                            Hoş Geldiniz, <span className="font-black text-blue-600">{kullaniciAdi}</span>
                            {yukleniyor && <i className="fas fa-circle-notch fa-spin text-blue-400 ml-2 text-sm"></i>}
                        </h1>
                    </div>
                    <div className="flex items-center gap-3">
                        <div className="w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center text-white font-black text-sm">{kullaniciAdi.charAt(0).toUpperCase()}</div>
                        <span className="hidden md:block text-xs font-bold text-slate-500 uppercase">{isYonetici ? "Yönetici" : "Personel"}</span>
                    </div>
                </header>

                {/* SCROLLABLE CONTENT */}
                <div className="flex-1 overflow-y-auto p-4 md:p-6 space-y-4 md:space-y-6">

                    {/* 4 ÖZET KARTI */}
                    <div className="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4">
                        <div className="bg-white rounded-xl border border-slate-200 p-4 md:p-5 shadow-sm">
                            <div className="flex items-center justify-between mb-3">
                                <span className="text-[10px] md:text-xs font-bold text-slate-400 uppercase tracking-widest">Bugünkü Sipariş</span>
                                <div className="w-8 h-8 rounded-lg bg-blue-50 text-blue-500 flex items-center justify-center"><i className="fas fa-shopping-cart text-sm"></i></div>
                            </div>
                            <p className="text-2xl md:text-3xl font-black text-slate-800">{bugunkuSiparisler.length}</p>
                            <p className="text-[10px] font-bold text-slate-400 mt-1">adet sipariş geldi</p>
                        </div>

                        <div className="bg-white rounded-xl border border-slate-200 p-4 md:p-5 shadow-sm">
                            <div className="flex items-center justify-between mb-3">
                                <span className="text-[10px] md:text-xs font-bold text-slate-400 uppercase tracking-widest">Bugünkü Ciro</span>
                                <div className="w-8 h-8 rounded-lg bg-emerald-50 text-emerald-500 flex items-center justify-center"><i className="fas fa-coins text-sm"></i></div>
                            </div>
                            <p className="text-xl md:text-2xl font-black text-emerald-600">{bugunkuCiro.toLocaleString("tr-TR", { minimumFractionDigits: 2 })}</p>
                            <p className="text-[10px] font-bold text-slate-400 mt-1">TL ciro yapıldı</p>
                        </div>

                        <div className="bg-white rounded-xl border border-slate-200 p-4 md:p-5 shadow-sm">
                            <div className="flex items-center justify-between mb-3">
                                <span className="text-[10px] md:text-xs font-bold text-slate-400 uppercase tracking-widest">Bekleyen Sipariş</span>
                                <div className="w-8 h-8 rounded-lg bg-amber-50 text-amber-500 flex items-center justify-center"><i className="fas fa-clock text-sm"></i></div>
                            </div>
                            <p className="text-2xl md:text-3xl font-black text-amber-600">{bekleyenSayisi}</p>
                            <p className="text-[10px] font-bold text-slate-400 mt-1">işlem bekliyor</p>
                        </div>

                        <div className="bg-white rounded-xl border border-slate-200 p-4 md:p-5 shadow-sm">
                            <div className="flex items-center justify-between mb-3">
                                <span className="text-[10px] md:text-xs font-bold text-slate-400 uppercase tracking-widest">Toplam Müşteri</span>
                                <div className="w-8 h-8 rounded-lg bg-indigo-50 text-indigo-500 flex items-center justify-center"><i className="fas fa-users text-sm"></i></div>
                            </div>
                            <p className="text-2xl md:text-3xl font-black text-slate-800">{toplamMusteri}</p>
                            <p className="text-[10px] font-bold text-slate-400 mt-1">kayıtlı müşteri</p>
                        </div>

                        {bekleyenB2B > 0 && (
                            <div className="bg-white rounded-xl border-2 border-red-200 p-4 md:p-5 shadow-sm col-span-2 lg:col-span-4 relative overflow-hidden">
                                <div className="absolute top-0 right-0 w-24 h-24 bg-red-50 rounded-bl-full opacity-50"></div>
                                <div className="flex items-center justify-between relative">
                                    <div className="flex items-center gap-4">
                                        <div className="w-12 h-12 rounded-xl bg-red-100 text-red-600 flex items-center justify-center shrink-0 relative">
                                            <i className="fas fa-handshake text-xl"></i>
                                            <span className="absolute -top-1.5 -right-1.5 w-6 h-6 bg-red-600 text-white rounded-full flex items-center justify-center text-[10px] font-black animate-pulse">{bekleyenB2B}</span>
                                        </div>
                                        <div>
                                            <h3 className="text-sm font-black text-slate-800">Bekleyen B2B Bağlantı İstekleri</h3>
                                            <p className="text-xs text-slate-500 mt-0.5"><span className="font-black text-red-600">{bekleyenB2B}</span> adet market/müşteri sizinle bağlantı kurmak istiyor</p>
                                        </div>
                                    </div>
                                    <Link href="/cari?sekme=istekler" className="px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white font-black text-xs uppercase tracking-widest rounded-xl shadow-md transition-all flex items-center gap-2 shrink-0">
                                        <i className="fas fa-eye"></i> İncele
                                    </Link>
                                </div>
                            </div>
                        )}
                    </div>

                    {/* AYLIK SATIŞ GRAFİĞİ (Recharts) */}
                    <div className="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                        <div className="p-4 md:p-5 border-b border-slate-100 flex items-center justify-between">
                            <div>
                                <h2 className="text-sm md:text-base font-black text-slate-800">Aylık Satış Grafiği</h2>
                                <p className="text-[10px] font-bold text-slate-400 mt-0.5">Son 6 aylık ciro dağılımı</p>
                            </div>
                            <div className="flex items-center gap-2 text-[10px] font-bold text-slate-400">
                                <div className="w-3 h-3 rounded bg-blue-500"></div> Ciro (TL)
                            </div>
                        </div>
                        <div className="p-4 md:p-6" style={{ height: 320 }}>
                            <ResponsiveContainer width="100%" height="100%">
                                <BarChart data={aylikGrafik} margin={{ top: 5, right: 10, left: 0, bottom: 5 }}>
                                    <CartesianGrid strokeDasharray="3 3" stroke="#e2e8f0" />
                                    <XAxis dataKey="ay" tick={{ fontSize: 11, fontWeight: 700, fill: "#94a3b8" }} axisLine={{ stroke: "#e2e8f0" }} tickLine={false} />
                                    <YAxis tick={{ fontSize: 10, fontWeight: 600, fill: "#94a3b8" }} axisLine={false} tickLine={false} tickFormatter={(v: number) => v >= 1000 ? `${(v / 1000).toFixed(0)}K` : v.toString()} />
                                    <Tooltip
                                        contentStyle={{ backgroundColor: "#1e293b", border: "none", borderRadius: 8, padding: "8px 12px" }}
                                        labelStyle={{ color: "#94a3b8", fontSize: 11, fontWeight: 700 }}
                                        itemStyle={{ color: "#fff", fontSize: 13, fontWeight: 800 }}
                                        formatter={(value) => [`${Number(value).toLocaleString("tr-TR", { minimumFractionDigits: 2 })} TL`, "Ciro"]}
                                    />
                                    <Bar dataKey="tutar" fill="#3b82f6" radius={[6, 6, 0, 0]} maxBarSize={50} />
                                </BarChart>
                            </ResponsiveContainer>
                        </div>
                    </div>

                    {/* ALT ALAN: SON SİPARİŞLER + HIZLI İŞLEMLER */}
                    <div className="grid grid-cols-1 lg:grid-cols-3 gap-4 md:gap-6">
                        {/* SON SİPARİŞLER */}
                        <div className="lg:col-span-2 bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                            <div className="p-4 border-b border-slate-100 flex items-center justify-between">
                                <h2 className="text-sm font-black text-slate-800"><i className="fas fa-clock text-slate-400 mr-2"></i>Son Siparişler</h2>
                                <Link href="/" className="text-[10px] font-bold text-blue-600 hover:text-blue-800">Tümünü Gör <i className="fas fa-arrow-right ml-1"></i></Link>
                            </div>
                            <div className="overflow-x-auto">
                                <table className="w-full text-left min-w-[500px]">
                                    <thead className="bg-slate-50 border-b border-slate-200">
                                        <tr className="text-[10px] font-bold text-slate-500 uppercase tracking-widest">
                                            <th className="p-3">Fiş No</th>
                                            <th className="p-3">Müşteri</th>
                                            <th className="p-3 text-right">Tutar</th>
                                            <th className="p-3 text-center">Durum</th>
                                            <th className="p-3 text-center">Tarih</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {sonBesSiparis.length === 0 ? (
                                            <tr><td colSpan={5} className="p-6 text-center text-slate-400 font-bold uppercase tracking-widest text-xs">Sipariş bulunamadı</td></tr>
                                        ) : (
                                            sonBesSiparis.map(s => (
                                                <tr key={s.id} className="text-xs border-b border-slate-100 hover:bg-slate-50 transition-colors">
                                                    <td className="p-3 font-bold text-slate-600">{s.siparis_no || `#${s.id}`}</td>
                                                    <td className="p-3 font-bold text-slate-800">{s.musteriAdi}</td>
                                                    <td className="p-3 text-right font-black text-slate-800">{parseTutar(s.toplam_tutar).toLocaleString("tr-TR", { minimumFractionDigits: 2 })}</td>
                                                    <td className="p-2 text-center"><span className={`${durumBadge(s.durum)} px-2 py-0.5 rounded text-[9px] font-black uppercase`}>{s.durum}</span></td>
                                                    <td className="p-3 text-center text-slate-500">{s.created_at ? new Date(s.created_at).toLocaleDateString("tr-TR") : "-"}</td>
                                                </tr>
                                            ))
                                        )}
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        {/* HIZLI İŞLEMLER */}
                        <div className="bg-white rounded-xl border border-slate-200 shadow-sm p-4">
                            <h2 className="text-sm font-black text-slate-800 mb-4 pb-2 border-b border-slate-100"><i className="fas fa-bolt text-amber-500 mr-2"></i>Hızlı İşlemler</h2>
                            <div className="space-y-2">
                                <Link href="/" className="flex items-center gap-3 p-3 rounded-lg hover:bg-blue-50 border border-transparent hover:border-blue-200 transition-all group">
                                    <div className="w-9 h-9 rounded-lg bg-blue-50 text-blue-500 flex items-center justify-center group-hover:scale-110 transition-transform shrink-0"><i className="fas fa-plus"></i></div>
                                    <div><p className="text-xs font-bold text-slate-800">Yeni Sipariş Fişi</p><p className="text-[10px] text-slate-400">Toptan satış kaydı aç</p></div>
                                </Link>
                                <Link href="/pos" className="flex items-center gap-3 p-3 rounded-lg hover:bg-emerald-50 border border-transparent hover:border-emerald-200 transition-all group">
                                    <div className="w-9 h-9 rounded-lg bg-emerald-50 text-emerald-500 flex items-center justify-center group-hover:scale-110 transition-transform shrink-0"><i className="fas fa-barcode"></i></div>
                                    <div><p className="text-xs font-bold text-slate-800">Hızlı Satış (POS)</p><p className="text-[10px] text-slate-400">Kasayı aç</p></div>
                                </Link>
                                <Link href="/tahsilat" className="flex items-center gap-3 p-3 rounded-lg hover:bg-orange-50 border border-transparent hover:border-orange-200 transition-all group">
                                    <div className="w-9 h-9 rounded-lg bg-orange-50 text-orange-500 flex items-center justify-center group-hover:scale-110 transition-transform shrink-0"><i className="fas fa-money-bill-wave"></i></div>
                                    <div><p className="text-xs font-bold text-slate-800">Tahsilat / Ödeme</p><p className="text-[10px] text-slate-400">Alacak tahsil et</p></div>
                                </Link>
                                <Link href="/stok" className="flex items-center gap-3 p-3 rounded-lg hover:bg-indigo-50 border border-transparent hover:border-indigo-200 transition-all group">
                                    <div className="w-9 h-9 rounded-lg bg-indigo-50 text-indigo-500 flex items-center justify-center group-hover:scale-110 transition-transform shrink-0"><i className="fas fa-box"></i></div>
                                    <div><p className="text-xs font-bold text-slate-800">Stok Yönetimi</p><p className="text-[10px] text-slate-400">Ürünleri düzenle</p></div>
                                </Link>
                            </div>
                        </div>
                    </div>
                </div>
        </main>
    );
}
